=== F2: K_{d,d} minus a matching of size t (symbolic t) ===
  mu series (eps=1/d): 2*(eps**2*t*(-2*eps**2*t - 4*eps**2 + 2*eps - 1) + 1)/eps
  Bound 44:
    edge (0, 2): coeffs (eps^0..eps^3) = [-1, (4*t + 9)/4, -(52*t - 35)/8, (272*t**2 + 216*t + 435)/64]
    edge (0, 3): coeffs (eps^0..eps^3) = [-1/2, (16*t + 23)/16, -(368*t - 147)/64, (4352*t**2 + 5664*t + 2923)/1024]
    edge (1, 2): coeffs (eps^0..eps^3) = [-1/2, (16*t + 23)/16, -(368*t - 147)/64, (4352*t**2 + 5664*t + 2923)/1024]
    edge (1, 3): coeffs (eps^0..eps^3) = [0, t, -5*t, t*(17*t + 28)/4]
  Bound 46:
    edge (0, 2): coeffs (eps^0..eps^3) = [-2, 2*(t + 1), -2*(3*t - 2), 4*t**2 + 6*t + 5]
    edge (0, 3): coeffs (eps^0..eps^3) = [-1, (8*t + 5)/4, -(48*t - 23)/8, (256*t**2 + 384*t + 251)/64]
    edge (1, 2): coeffs (eps^0..eps^3) = [-1, (8*t + 5)/4, -(48*t - 23)/8, (256*t**2 + 384*t + 251)/64]
    edge (1, 3): coeffs (eps^0..eps^3) = [0, 2*t, -6*t, 2*t*(2*t + 3)]
=== F2c: K_{d,d} minus matching of size d-u (symbolic u >= 1) ===
  mu series: -4*eps**3*u**2 + 8*eps**3*u + 4*eps**2*u + 2*eps*u - 2 + 2/eps
  Bound 44:
    edge (0, 2): coeffs = [0, -u, -2*u, u*(17*u - 16)/4]
    edge (0, 3): coeffs = [1/2, -(16*u + 1)/16, -(176*u + 7)/64, (4352*u**2 - 5920*u - 197)/1024]
    edge (1, 2): coeffs = [1/2, -(16*u + 1)/16, -(176*u + 7)/64, (4352*u**2 - 5920*u - 197)/1024]
    edge (1, 3): coeffs = [1, -(4*u + 3)/4, -(28*u + 9)/8, (272*u**2 - 440*u - 117)/64]
  Bound 46:
    edge (0, 2): coeffs = [0, -2*u, -2*u, 2*u*(2*u - 1)]
    edge (0, 3): coeffs = [1, -(8*u + 3)/4, -(16*u + 9)/8, (256*u**2 - 128*u - 117)/64]
    edge (1, 2): coeffs = [1, -(8*u + 3)/4, -(16*u + 9)/8, (256*u**2 - 128*u - 117)/64]
    edge (1, 3): coeffs = [2, -2*(u + 1), -2*(u + 2), 4*u**2 - 2*u - 7]
